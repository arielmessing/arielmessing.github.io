---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Finis from "../components/Finis.astro";
---

<Layout title="Ariel Messing">
  <script slot="head" type="application/ld+json" set:html={
    JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Ariel Messing",
      "description": "Writing about well-made code, thoughtful design, and slow bread.",
      "url": Astro.site?.href,
    }) 
  } />
    
  <section class="home">
    <header class="home-header">
      <hgroup role="group">
        <p class="greeting">hello, I'm</p>
        <Heading as="h1">ariel</Heading>
        <p class="pronunciation" aria-label="pronounced: ah-ree-elle">[ ah—ree—ELLE ]</p>
        <p class="description">
          and I appreciate thoughtful design, well-made code, and slow bread
        </p>
    </hgroup>
  </header>

    <Finis />
  </section>
</Layout>

<style>
.home-header hgroup {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.greeting {
  font-family: var(--font-heading);
  color: var(--color-text-tertiary);
  font-size: 0.9375rem;
  letter-spacing: -0.02em;
}

.pronunciation {
  font-family: var(--font-mono);
  color: var(--color-text-tertiary);
  font-size: 0.85em;
}

.description {
  margin-top: var(--space-md);
  font-family: var(--font-body);
  font-style: italic;
  color: var(--color-text-secondary);
  font-size: 1.125rem;
  max-width: 36ch;
}

</style>
