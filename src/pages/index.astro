---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Finis from "../components/Finis.astro";

export const title = "Ariel Messing";
const description = "Ariel Messing's website: A quiet place to read.";
---

<Layout title={title} description={description}>
  <script slot="head" type="application/ld+json" set:html={
    JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": title,
      "description": description,
      "url": Astro.site?.href,
    }) 
  } />
    
  <section class="home">
    <header class="home-header">
      <p class="preamble">hello, I'm</p>

      <Heading as="h1">Ariel</Heading>

      <p class="qualifier" aria-label="pronounced: ah-ree-ELLE">[ ah—ree—<em>elle</em> ]</p>

      <p class="tagline">
        developer by trade, antiquarian by inclination; I appreciate thoughtful design, well-made code, and slow living
      </p>
    </header>

    <Finis />
  </section>
</Layout>

<style>
  .preamble {
    font-family: var(--font-heading);
    color: var(--color-text-tertiary);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: var(--space-md);
  }

  .qualifier {
    font-family: var(--font-body);
    color: var(--color-text-tertiary);
  }

  .tagline {
    margin-top: var(--space-lg);
    font-family: var(--font-body);
    color: var(--color-text-secondary);
    font-size: 1.125rem;
  }
</style>
