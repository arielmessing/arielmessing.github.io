---
import { getCollection, render } from "astro:content";
import { isRevised, dateOf } from "../../utils/notes";

import Layout from "../../components/Layout.astro";
import Article from "../../components/Article.astro";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => ({
    params: { slug: note.id },
    props: note,
  }));
}

const note = Astro.props;
const { Content } = await render(note);

const noteUrl = new URL(`/notes/${note.id}`, Astro.site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": note.data.title,
  "description": note.data.description,
  "datePublished": note.data.date.toISOString(),
  "dateModified": note.data.revised?.toISOString(),
  "url": noteUrl,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": noteUrl,
  },
  "author": {
    "@type": "Person",
    "name": "Ariel Messing",
    "url": Astro.site?.href,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Ariel Messing",
    "url": Astro.site?.href,
  },
};
---

<Layout title={`${note.data.title} - Ariel Messing`} description={note.data.description} ogType="article">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Article title={note.data.title} 
          date={dateOf(note)} 
          isRevised={isRevised(note)} 
          tags={note.data.tags}>
    <Content />
  </Article>
</Layout>
