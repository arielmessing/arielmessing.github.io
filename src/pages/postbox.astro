---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Prose from "../components/Prose.astro";
import Finis from "../components/Finis.astro";

import { CONTACT_FORM_CONFIG } from '../config.ts';

const successPage = new URL('/thanks', Astro.site).href;
---

<Layout title="Postbox - Ariel Messing">
  <script slot="head" type="application/ld+json" set:html={
    JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "Postbox - Ariel Messing",
      "description": "Get in touch with Ariel Messing.",
      "url": new URL("/postbox", Astro.site).href,
      "isPartOf": {
        "@type": "WebSite",
        "name": "Ariel Messing",
        "url": Astro.site?.href,
      }
    }) 
  } />

  <section class="postbox">
    <header class="postbox-header">
      <Heading as="h1">@arielmessing</Heading>
    </header>
    <Prose>
      <p class="postbox-intro">
        From system design, through the Habsburgs, to that eternal question: jam or cream first — I’m always up for a chat
      </p>

      <form class="postbox-form" action={CONTACT_FORM_CONFIG.END_POINT} method="POST">
        <input type="hidden" name="access_key" value={CONTACT_FORM_CONFIG.PUBLIC_KEY}>
        <input type="hidden" name="redirect" value={successPage} />

        <input type="text" id="name" name="name" placeholder="name" autocomplete="name" aria-label="Full Name" required>

        <input type="email" id="email" name="email" placeholder="email" autocomplete="email" aria-label="Email Address" required>

        <textarea id="message" name="message" placeholder="message" aria-label="Message" required></textarea>

        <button type="submit" class="submit-button">
          <span>post</span>
        </button>
      </form>
      
      <p class="postbox-disclaimer">
        Responses may be slow, but I read every email.
      </p>
    </Prose>
    <Finis />
  </section>
</Layout>

<style>
  .postbox {
    max-width: var(--width-content);
  }

  .postbox-header {
    margin-bottom: var(--space-2xl);
  }

  .postbox-intro {
    max-width: 50ch;
  }

  .postbox-disclaimer {
    font-size: 0.9375rem;
    color: var(--color-text-tertiary);
  }

  .postbox-form {
    max-width: var(--width-content);
    margin: var(--space-xl) auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .postbox-form input,
  .postbox-form textarea {
    font-family: var(--font-body);
    font-size: 1.125rem;
    padding: var(--space-sm) 0;
    color: var(--color-text);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-border);
    border-radius: 0;
    transition: border-color 0.3s ease;
    outline: none;
  }

  .postbox-form textarea {
    min-height: 120px;
    resize: vertical;
    line-height: 1.5;
  }

  .postbox-form input:focus,
  .postbox-form textarea:focus {
    border-bottom-color: var(--color-accent-muted);
  }

  .postbox-form input::placeholder,
  .postbox-form textarea::placeholder {
    color: var(--color-text-tertiary);
    opacity: 0.45;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
  }

  .submit-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background-color: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .submit-button span {
    color: var(--color-text-secondary);
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .submit-button:hover {
    background-color: var(--color-selection);
    border-color: var(--color-accent-muted);
  }

  .submit-button:hover span {
    color: var(--color-accent);
  }
</style>