---
import { getCollection } from "astro:content";
import { byDateDesc } from "../utils/notes";

import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import NoteList from "../components/NoteList.astro";
import Finis from "../components/Finis.astro";

import { title as indexTitle } from "./index.astro";

const title = "Notes & Sketches ~ Ariel Messing";
const description = "A digital notebook of thoughts, observations, experiments, and general musings where the natural world meets the written word and curly brackets.";

const notes = (await getCollection("notes"))
  .sort(byDateDesc);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": title,
  "description": description,
  "numberOfItems": notes.length,
  "itemListElement": notes.map((note, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "BlogPosting",
      "headline": note.data.title,
      "url": new URL(`/notes/${note.id}`, Astro.site).href,
      "datePublished": note.data.date.toISOString()
    }
  })),
  "url": new URL("/notes", Astro.site).href,
  "isPartOf": {
    "@type": "WebSite",
    "name": indexTitle,
    "url": Astro.site?.href,
  }
};
---

<Layout title={title} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <section class="notes">
    <header class="notes-header">
      <Heading as="h1">Notes</Heading>
    </header>
    
    <NoteList items={notes} />

    <footer>
      <Finis />
    </footer>
  </section>
</Layout>

<style>
  .notes {
    max-width: var(--width-content);
  }

  .notes-header {
    margin-bottom: var(--space-2xl);
  }
</style>