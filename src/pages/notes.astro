---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import { getCollection } from "astro:content";

const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Notes">
  <section class="notes">
    <header class="notes-header">
      <Heading as="h1">Notes</Heading>
    </header>
    <ul class="note-list">
      {
        notes.map((note) => {
          const formattedDate = note.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          return (
            <li class="note-item">
              <a href={`/notes/${note.id}`}>
                <span class="note-title">{note.data.title}</span>
                <span class="note-description">{note.data.description}</span>
                <time datetime={note.data.date.toISOString()}>{formattedDate}</time>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</Layout>

<style>
  .notes {
    max-width: var(--width-content);
  }

  .notes-header {
    margin-bottom: var(--space-2xl);
  }

  .note-list {
    list-style: none;
    padding: 0;
  }

  .note-item {
    border-bottom: 1px solid var(--color-border);
  }

  .note-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .note-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) 0;
    text-decoration: none;
    color: var(--color-text);
  }

  .note-item a:hover .note-title {
    color: var(--color-text-secondary);
  }

  .note-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .note-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .note-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
  }
</style>