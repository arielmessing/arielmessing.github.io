---
import type { CollectionEntry } from 'astro:content';
import { isRevised, dateOf } from "../utils/notes";
import { formatDate } from '../utils/datetime';

type Note = CollectionEntry<"notes">;

interface Props {
  items: Note[];
}

const { items } = Astro.props;
---

<ul class="note-list">
  {
    items.map(note => {
      const date = dateOf(note);
      const formattedDate = formatDate(date);

      const primaryTag = note.data.tags?.[0];

      return (
        <li class="note-item">
            <a href={`/notes/${note.id}`}>
            <span class="note-title">{note.data.title}</span>
            <span class="note-description">{note.data.description}</span>
            <span class="note-meta">
                <time datetime={date.toISOString()} data-is-revised={isRevised(note)}>{formattedDate}</time>
                {primaryTag && <span class="tag-name">{primaryTag}</span>}
            </span>
            </a>
        </li>
      );
    })
  }
</ul>

<style>
  .note-list {
    list-style: none;
    padding: 0;
  }

  .note-item {
    border-bottom: 1px solid var(--color-border);
  }

  .note-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .note-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) 0;
    text-decoration: none;
    color: var(--color-text);
  }

  .note-item a:hover .note-title {
    color: var(--color-text-secondary);
  }

  .note-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .note-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .note-meta {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
    display: flex;
    gap: var(--space-md);
  }

  .note-meta time[data-is-revised="true"]::after {
    content: "+";
    opacity: 0.45;
    position: absolute;
    margin-left: 2px;
  }

  .tag-name::before {
    content: "#";
    opacity: 0.45;
  }
</style>