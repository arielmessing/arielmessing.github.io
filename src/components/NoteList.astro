---
import type { CollectionEntry } from 'astro:content';

interface Props {
  items: CollectionEntry<"notes">[];
}

const { items } = Astro.props;
---

<ul class="note-list">
  {
    items.map(note => {
      const formattedDate = note.data.date.toLocaleDateString("en-GB", {
        year: "numeric",
        month: "long",
        day: "numeric",
      });

      const mainTagName = note.data.tags?.[0];

      return (
        <li class="note-item">
            <a href={`/notes/${note.id}`}>
            <span class="note-title">{note.data.title}</span>
            <span class="note-description">{note.data.description}</span>
            <span class="note-meta">
                <time datetime={note.data.date.toISOString()} data-is-revised={!!note.data.revised}>{formattedDate}</time>
                {mainTagName && <span class="tag-name">{mainTagName}</span>}
            </span>
            </a>
        </li>
      );
    })
  }
</ul>

<style>
  .note-list {
    list-style: none;
    padding: 0;
  }

  .note-item {
    border-bottom: 1px solid var(--color-border);
  }

  .note-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .note-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) 0;
    text-decoration: none;
    color: var(--color-text);
  }

  .note-item a:hover .note-title {
    color: var(--color-text-secondary);
  }

  .note-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .note-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .note-meta {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
    display: flex;
    gap: var(--space-md);
  }

  .tag-name::before {
    content: "#";
    opacity: 0.45;
  }
</style>