---
const year = new Date().getFullYear();
---

<footer class="footer">
  <p>&copy; {year} Ariel Messing. All rights reserved.</p>

  <nav class="socials-links" aria-label="Social media links">
    <a href="https://linkedin.com/in/arielmessing" 
      aria-label="LinkedIn"
      rel="noopener noreferrer" 
      target="_blank">in</a>

    <a href="https://github.com/arielmessing" 
      aria-label="GitHub"
      rel="noopener noreferrer" 
      target="_blank">&#123; &#125;</a>

    <a href="https://x.com/arielmessing" 
      aria-label="X (formerly Twitter)"
      rel="noopener noreferrer" 
      target="_blank">𝕏</a>
  </nav>
</footer>

<style>
  .footer {
    display: flex;
    flex-direction: column-reverse;
    gap: var(--space-md);
    align-items: center;
    
    margin-top: var(--space-2xl);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .footer {
      flex-direction: row;
      justify-content: space-between;
      align-items: baseline;
    }
  }

  .footer p,
  .footer a {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .socials-links {
    display: flex;
    gap: var(--space-lg);
  }

  .socials-links a {
    text-decoration: none;
  }

  .socials-links a:hover {
    color: var(--color-accent);
  }
</style>
