---
const year = new Date().getFullYear();
---

<footer class="footer">
  <p>&copy; {year} Ariel Messing. All rights reserved.</p>

  <div class="socials-links">
    <a href="https://linkedin.com/in/arielmessing" title="LinkedIn" target="_blank">in</a>
    <a href="https://github.com/arielmessing" title="GitHub" target="_blank">&#123; &#125;</a>
    <a href="https://x.com/ariel.messing" title="X (formerly known as Twitter)" target="_blank">𝕏</a>
  </div>
</footer>

<style>
  .footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: var(--space-2xl);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
  }

  .footer p {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .socials-links {
    display: flex;
    gap: var(--space-lg);
  }

  .socials-links a {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    text-decoration: none;
  }

  .socials-links a:hover {
    color: var(--color-text-secondary);
  }
</style>
